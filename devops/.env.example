# =============================================================
# Skill-Hive DevOps — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git. Only commit this .env.example file.
# =============================================================

# --- App ---
PORT=5000
MONGO_URI=mongodb://mongodb:27017/skillswap_chat

# --- JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET=your_jwt_secret_here

# --- Chat Encryption (generate with: openssl rand -base64 32) ---
CHAT_ENCRYPTION_KEY=your_chat_encryption_key_here

# --- Email (Gmail App Password) ---
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
